# ===========================
# GROQ API (OBLIGATORIO)
# ===========================
# Obtén tu API Key gratis en: https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_api_key_aqui

# ===========================
# BASE DE DATOS
# ===========================
# PostgreSQL (para desarrollo local SIN Docker)
# DATABASE_URL=postgresql://nationmind:dev123@localhost:5432/nationmind_db

# PostgreSQL (cuando usas Docker Compose) ← USAR ESTE EN DOCKER
DATABASE_URL=postgresql://nationmind:dev123@postgres:5432/nationmind_db

# ===========================
# CHROMADB
# ===========================
# ChromaDB (local SIN Docker)
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8001
# USE_CHROMADB_HTTP=False

# ChromaDB (con Docker Compose) ← USAR ESTE EN DOCKER
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
USE_CHROMADB_HTTP=True

# ===========================
# REDIS (OPCIONAL)
# ===========================
REDIS_URL=redis://redis:6379

# ===========================
# CONFIGURACIÓN LLM
# ===========================
# Modelos disponibles en Groq:
# - llama-3.3-70b-versatile (mejor calidad, 100k tokens/día)
# - llama-3.1-8b-instant (más rápido, 30k tokens/min) ← RECOMENDADO
# - gemma2-9b-it (alternativa, 15k tokens/min)
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ===========================
# ENTORNO
# ===========================
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=tu_secret_key_super_seguro_aqui

# ===========================
# SEGURIDAD
# ===========================
# API key para endpoints sensibles (dejar vacio en local si quieres)
API_KEY=

# Rate limiting (0 = desactivado)
RATE_LIMIT_MAX_REQUESTS=0
RATE_LIMIT_WINDOW_SECONDS=60

# ===========================
# CORS SETTINGS
# ===========================
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================
# FRONTEND (Next.js)
# ===========================
# URL del backend (desde el navegador del usuario)
NEXT_PUBLIC_API_URL=http://localhost:8000
